{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocsPI",
  "version": "1.0.0",
  "identifier": "com.aydocs.docspi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DocsPI",
        "width": 380,
        "height": 700,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "devtools": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost https://api.github.com; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; worker-src 'none'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/docspi-proxy",
      "binaries/docspi-divert"
    ],
    "resources": {
      "binaries/npcap-installer.exe": "npcap-installer.exe",
      "binaries/WinDivert.dll": "WinDivert.dll",
      "binaries/WinDivert64.sys": "WinDivert64.sys"
    },
    "targets": ["nsis", "msi", "app", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "hooks.nsi"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "exceptionDomain": "",
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
